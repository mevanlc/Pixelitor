#!/usr/bin/env bash

set -euo pipefail

readonly APP_NAME="Pixelitor"
readonly MIN_JAVA_VERSION=25
readonly DESTINATION="/Applications/${APP_NAME}.app"
REPO_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "This script can only create and install the macOS app bundle." >&2
    exit 1
fi

if ! which mvn >/dev/null 2>&1; then
    echo "Maven is required but was not found on PATH." >&2
    exit 1
fi

jdk_is_compatible() {
    local jdk_home="$1"
    local javac_version
    local major_version

    [[ -x "${jdk_home}/bin/javac" && -x "${jdk_home}/bin/jpackage" ]] || return 1

    javac_version="$("${jdk_home}/bin/javac" -version 2>&1)"
    javac_version="${javac_version#javac }"
    major_version="${javac_version%%.*}"

    [[ "$major_version" =~ ^[0-9]+$ && "$major_version" -ge "$MIN_JAVA_VERSION" ]]
}

jdk_home="${JAVA_HOME:-}"
if ! jdk_is_compatible "$jdk_home"; then
    jdk_home="$(/usr/libexec/java_home 2>/dev/null || true)"
fi

if ! jdk_is_compatible "$jdk_home"; then
    echo "A JDK ${MIN_JAVA_VERSION}+ containing jpackage is required." >&2
    echo "Set JAVA_HOME to a compatible JDK and try again." >&2
    exit 1
fi

export JAVA_HOME="$jdk_home"
export PATH="${JAVA_HOME}/bin:${PATH}"

cd "$REPO_DIR"

echo "Building Pixelitor with ${JAVA_HOME}..."
mvn clean package -Dmaven.test.skip=true

jar_path="$(find "$REPO_DIR/target" -maxdepth 1 -type f -name 'Pixelitor-*.jar' -print -quit)"
if [[ -z "$jar_path" ]]; then
    echo "The Pixelitor JAR was not found after the Maven build." >&2
    exit 1
fi

jar_name="$(basename "$jar_path")"
app_version="${jar_name#Pixelitor-}"
app_version="${app_version%.jar}"
module_deps="$("${JAVA_HOME}/bin/jdeps" --ignore-missing-deps --print-module-deps "$jar_path")"

work_dir="$(mktemp -d "${TMPDIR:-/tmp}/pixelitor-jpackage.XXXXXX")"
trap 'rm -rf -- "$work_dir"' EXIT

input_dir="${work_dir}/input"
iconset_dir="${work_dir}/${APP_NAME}.iconset"
icon_path="${work_dir}/${APP_NAME}.icns"
mkdir "$input_dir" "$iconset_dir"
cp "$jar_path" "$input_dir"

for size in 16 32 128; do
    double_size=$((size * 2))
    sips -z "$size" "$size" \
        "$REPO_DIR/src/main/resources/images/pixelitor_icon256.png" \
        --out "${iconset_dir}/icon_${size}x${size}.png" >/dev/null
    sips -z "$double_size" "$double_size" \
        "$REPO_DIR/src/main/resources/images/pixelitor_icon256.png" \
        --out "${iconset_dir}/icon_${size}x${size}@2x.png" >/dev/null
done
iconutil -c icns "$iconset_dir" -o "$icon_path"

echo "Creating ${APP_NAME}.app..."
"${JAVA_HOME}/bin/jpackage" \
    --type app-image \
    --name "$APP_NAME" \
    --app-version "$app_version" \
    --description "Pixelitor image editor" \
    --vendor "Pixelitor" \
    --input "$input_dir" \
    --main-jar "$jar_name" \
    --main-class pixelitor.Pixelitor \
    --add-modules "$module_deps" \
    --icon "$icon_path" \
    --mac-package-identifier io.sourceforge.pixelitor \
    --dest "$work_dir"

echo "Installing ${DESTINATION}..."
rm -rf -- "$DESTINATION"
mv -- "${work_dir}/${APP_NAME}.app" "$DESTINATION"

echo "Installed ${DESTINATION}"
